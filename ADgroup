Full script with output report

Use this if you want a result CSV.

$CsvPath = "C:\Temp\exportGroupMembers.csv"
$TargetGroupName = "paz_app_myID_tr1_groups"
$OutputCsv = "C:\Temp\Add-Groups-To-TR1-Result.csv"

$TargetGroupId = az ad group show `
  --group $TargetGroupName `
  --query id `
  -o tsv

if ([string]::IsNullOrWhiteSpace($TargetGroupId)) {
    throw "Target group not found: $TargetGroupName"
}

Write-Host "Target group: $TargetGroupName"
Write-Host "Target group id: $TargetGroupId"

$members = Import-Csv $CsvPath
$results = @()

foreach ($member in $members) {

    $MemberGroupId = $member.id
    $MemberDisplayName = $member.displayName

    if ([string]::IsNullOrWhiteSpace($MemberGroupId)) {
        $results += [PSCustomObject]@{
            DisplayName = $MemberDisplayName
            MemberId    = $MemberGroupId
            Status      = "Skipped"
            Message     = "Empty id"
        }
        continue
    }

    try {
        Write-Host "`nProcessing: $MemberDisplayName | $MemberGroupId"

        $check = az ad group member check `
          --group $TargetGroupId `
          --member-id $MemberGroupId `
          --query value `
          -o tsv

        if ($check -eq "true") {
            Write-Host "Already member. Skipping." -ForegroundColor Yellow

            $results += [PSCustomObject]@{
                DisplayName = $MemberDisplayName
                MemberId    = $MemberGroupId
                Status      = "AlreadyExists"
                Message     = "Group is already member of target group"
            }

            continue
        }

        az ad group member add `
          --group $TargetGroupId `
          --member-id $MemberGroupId

        Write-Host "Added successfully." -ForegroundColor Green

        $results += [PSCustomObject]@{
            DisplayName = $MemberDisplayName
            MemberId    = $MemberGroupId
            Status      = "Added"
            Message     = "Added to target group"
        }
    }
    catch {
        Write-Warning "Failed for $MemberDisplayName | $MemberGroupId : $($_.Exception.Message)"

        $results += [PSCustomObject]@{
            DisplayName = $MemberDisplayName
            MemberId    = $MemberGroupId
            Status      = "Failed"
            Message     = $_.Exception.Message
        }
    }
}

$results | Export-Csv $OutputCsv -NoTypeInformation -Encoding UTF8

Write-Host "`nCompleted."
Write-Host "Output report: $OutputCsv"
